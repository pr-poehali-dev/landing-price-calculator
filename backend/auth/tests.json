{
  "tests": [
    {
      "name": "Login with empty fields returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register duplicate user returns 409",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "login": "testuser_legis24", "password": "secret123"},
      "expectedStatus": 409,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "testuser_legis24", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "testuser_legis24", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}