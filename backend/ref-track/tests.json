{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing ref_code",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "ref_code required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Track unknown ref_code",
      "method": "POST",
      "path": "/",
      "body": {"ref_code": "TEST000000"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    }
  ]
}
